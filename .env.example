# Skopiuj zawartość do /etc/miniportal/miniportal.env.
# Nie wpisuj prawdziwych haseł do tego pliku w repozytorium.

APP_NAME="miniPORTAL"
APP_DEBUG=false
APP_TIMEZONE="Europe/Warsaw"
APP_THEME="default"
SESSION_NAME="MINIPORTALSESSID"
SESSION_SAME_SITE="Lax"
AUTH_STORAGE="database"
AUTH_DEMO_ENABLED=false
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_CALLBACK_URL="https://new.syntaxdevteam.pl/index.php?route=/admin/auth/github/callback"

DB_ENABLED=true
DB_DRIVER="mysql"
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_NAME="miniportal"
DB_USER="miniportal_user"
DB_PASS="wstaw_tutaj_silne_haslo"
DB_CHARSET="utf8mb4"
DB_COLLATION="utf8mb4_general_ci"
DB_LOGGING=false
