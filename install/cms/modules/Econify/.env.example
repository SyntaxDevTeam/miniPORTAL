# Skopiuj jako modules/Econify/.env. Użyj 0600 dla właściciela WWW albo 0640 z grupą WWW.
# Alternatywnie wskaż dowolny plik przez ECONIFY_ENV_FILE.

# Sekret nagłówka X-Econify-Token używany pomiędzy backendem bota a miniPORTAL.
ECONIFY_API_TOKEN="wygeneruj_niezalezny_losowy_sekret_minimum_32_znaki"

# Dane dedykowanej aplikacji utworzonej w Discord Developer Portal dla Econify.
ECONIFY_DISCORD_CLIENT_ID=""
ECONIFY_DISCORD_CLIENT_SECRET=""
ECONIFY_DISCORD_BOT_TOKEN=""
ECONIFY_DISCORD_CALLBACK_URL="https://econify.example.test/index.php?route=/econify/discord/callback"

# Liczba uprawnień z kalkulatora Discord. Zacznij od 0 i dodawaj minimum wymagane przez bota.
ECONIFY_DISCORD_BOT_PERMISSIONS=0
