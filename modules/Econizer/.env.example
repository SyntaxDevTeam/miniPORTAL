# Skopiuj jako config/modules/econizer.env. Użyj 0600 dla właściciela WWW albo 0640 z grupą WWW.
# Alternatywnie wskaż dowolny plik przez ECONIZER_ENV_FILE.

# Sekret nagłówka X-Econizer-Token używany pomiędzy backendem bota a miniPORTAL.
ECONIZER_API_TOKEN="wygeneruj_niezalezny_losowy_sekret_minimum_32_znaki"

# Dane dedykowanej aplikacji utworzonej w Discord Developer Portal dla Econizer.
# Nazwa i ikona tej aplikacji są widoczne na ekranie autoryzacji Discord.
# Ustaw je w portalu Discord jako Econizer zamiast używać roboczej aplikacji.
ECONIZER_DISCORD_CLIENT_ID=""
ECONIZER_DISCORD_CLIENT_SECRET=""
ECONIZER_DISCORD_BOT_TOKEN=""
ECONIZER_DISCORD_CALLBACK_URL="https://econizer.example.test/index.php?route=/econizer/discord/callback"

# Liczba uprawnień z kalkulatora Discord. Zacznij od 0 i dodawaj minimum wymagane przez bota.
ECONIZER_DISCORD_BOT_PERMISSIONS=0
