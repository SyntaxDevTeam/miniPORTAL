DirectoryIndex index.php

RewriteEngine On
RewriteCond %{HTTP_HOST} ^syntaxcraft\.pl$ [NC]
RewriteRule ^admin(?:/|$) https://www.syntaxcraft.pl%{REQUEST_URI} [R=302,L,NE]

RewriteRule ^auth/discord/callback/?$ auth/discord/callback/index.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z0-9-]+)/?$ index.php?page=$1 [L,QSA]
